# ===================================================================
#  J.A.R.V.I.S. Backend Configuration
#  Copy this file to `.env` and fill in your own keys.
#  NEVER commit `.env` with real keys.
# ===================================================================

# Which AI provider to use: claude | gemini | ollama | groq
ACTIVE_AI=claude

# --- Company branding / knowledge base ---
COMPANY_NAME=SYSNECT
ASSISTANT_NAME=J.A.R.V.I.S.
# Folder holding company knowledge files (.md/.txt). Default: backend/knowledge
# KNOWLEDGE_DIR=
KNOWLEDGE_CHAR_LIMIT=12000

# --- SYSNECT internal data search (admin-only [SYSNECT_DATA: query] tag) ---
# Comma-separated real folders on this machine to full-text search on demand
# (ticket dashboard source, DB schema, GLPI/n8n docs...). No char-limit ceiling
# like the knowledge base above, since files are searched live, not pre-loaded.
# Default (used when unset) covers sysnect-local-ai, the Ticket Dashboard
# project tree, and this JARVIS project itself.
# SYSNECT_DATA_DIRS=D:\AI Data\sysnect-local-ai,D:\SYSNECT  WORK SPACE\Sysnect Project Ticket\Sysnect html

# --- Anthropic / Claude ---
CLAUDE_API_KEY=
# Original model (kept for compatibility). NOTE: this ID is retired on the official
# Anthropic API since Apr 2026 — if you get a 404, use claude-haiku-4-5 instead,
# or set CLAUDE_BASE_URL to a compatible gateway (e.g. Z.ai) that still serves it.
CLAUDE_MODEL=claude-3-haiku-20240307
# CLAUDE_BASE_URL=https://your-gateway/v1

# --- Google Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Ollama (OpenAI-compatible local server) ---
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=jarvis

# --- Groq (OpenAI-compatible cloud, very fast — https://console.groq.com) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# --- Generation ---
MAX_TOKENS=1024
MAX_HISTORY=20
DOC_CONTEXT_LIMIT=15000
SESSION_TTL_SECONDS=3600
SESSION_TOKEN_TTL_SECONDS=43200

# --- Organizational identity / RBAC ---
# Enable these only after the hostname is protected by Cloudflare Access and
# backend traffic can arrive only through the local cloudflared connector.
TRUST_CLOUDFLARE_ACCESS_HEADERS=false
REQUIRE_ORG_IDENTITY=false
ORG_ALLOWED_DOMAINS=your-company.example
MANAGER_EMAILS=manager@your-company.example
ADMIN_EMAILS=admin@your-company.example

# --- Admin login (Authentication modal — type 'login' in the chat) ---
# Unlocks God Mode for a session. Leave ADMIN_PASSWORD empty to disable login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
# How long a login stays valid before the password is required again, in
# seconds (default 28800 = 8h). Admin status is memory-only and never survives
# a backend restart. 0 disables time expiry until restart (not recommended).
ADMIN_SESSION_TTL_SECONDS=28800

# --- Security monitor / auto-lockdown ---
# Continuously scores threat signals (failed logins, rate-limit trips, blocked
# injection/command attempts, path traversal...). Crossing SEC_LOCKDOWN_THRESHOLD
# within SEC_WINDOW_SECONDS seals every sensitive endpoint (503) for
# SEC_LOCKDOWN_SECONDS. A SECOND lockdown (a repeat offense, even after the
# first was cleared) escalates to INDEFINITE — no auto-recovery, must be
# cleared manually. See /api/security/status, POST /api/security/clear,
# POST /api/security/lockdown (admin panic button).
SEC_WARN_THRESHOLD=5
SEC_LOCKDOWN_THRESHOLD=10
SEC_WINDOW_SECONDS=120
SEC_LOCKDOWN_SECONDS=600
# Superadmin break-glass code to lift a lockdown WITHOUT needing an existing
# admin session (login itself is blocked during lockdown, by design — this is
# the escape hatch for when nobody was already logged in). Keep this DIFFERENT
# from ADMIN_PASSWORD and just as strong. Empty = feature disabled.
SECURITY_OVERRIDE_CODE=

# --- Security ---
# Comma-separated allowed origins. Use * only for local development.
CORS_ORIGINS=https://your-frontend.example.com,http://127.0.0.1:5500,http://localhost:5500
# Command execution is OFF by default because uploaded documents, web results,
# and chat history are prompt-injection inputs. Enable only after defining a
# narrow allowlist and an approval workflow:
#   ENABLE_COMMAND_EXECUTION=true   -> permit approved OPEN tools
#   ENABLE_SHELL_COMMANDS=false     -> keep arbitrary shell blocked
#   COMMAND_ALLOWLIST=notepad,calc  -> restrict which apps OPEN may launch (empty = any)
ENABLE_COMMAND_EXECUTION=false
ENABLE_SHELL_COMMANDS=false
REQUIRE_SHELL_CONFIRMATION=true
COMMAND_ALLOWLIST=notepad,calc
# Even in GOD MODE, a few irreversible drive-wiping commands (format, diskpart,
# whole-drive recursive delete) are blocked to protect the machine from a
# hallucinating model or a command injected via web search / uploaded files.
# Set to true to remove this last-resort guard entirely.
ALLOW_DESTRUCTIVE_COMMANDS=false

# --- Logging ---
LOG_LEVEL=INFO
